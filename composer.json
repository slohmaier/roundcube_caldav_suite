{
    "name": "slohmaier/roundcube_caldav_suite",
    "description": "CalDAV Calendar & Tasks plugin for Roundcube - connects to any CalDAV server",
    "type": "roundcube-plugin",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Stefan Lohmaier",
            "email": "stefan@slohmaier.de"
        }
    ],
    "homepage": "https://github.com/slohmaier/roundcube_caldav_suite",
    "keywords": ["roundcube", "caldav", "calendar", "tasks", "radicale", "baikal", "nextcloud"],
    "require": {
        "php": ">=8.1",
        "sabre/dav": "^4.6",
        "sabre/vobject": "^4.5",
        "roundcube/plugin-installer": ">=0.1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Slohmaier\\CalDAVSuite\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Slohmaier\\CalDAVSuite\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "test:all": "phpunit",
        "analyse": "phpstan analyse lib/ -l 6",
        "cs-fix": "php-cs-fixer fix lib/ tests/"
    },
    "config": {
        "allow-plugins": {
            "roundcube/plugin-installer": true
        }
    }
}
